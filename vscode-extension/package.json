{
  "name": "kor-local-agent-vscode",
  "displayName": "KOR Local Agent",
  "description": "Interface moderna do agente local KOR no Visual Studio Code.",
  "version": "1.0.0",
  "icon": "resources/KOR.png",
  "publisher": "jpachec0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpachec0/KOR.git"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:korAgent.chatView",
    "onCommand:korAgent.openChat",
    "onCommand:korAgent.askSelection",
    "onCommand:korAgent.newChat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "korAgent",
          "title": "KOR AI",
          "icon": "resources/KOR.svg"
        }
      ]
    },
    "views": {
      "korAgent": [
        {
          "id": "korAgent.chatView",
          "name": "Agent Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "korAgent.openChat",
        "title": "AI: Open Chat"
      },
      {
        "command": "korAgent.askSelection",
        "title": "AI: Ask Selection"
      },
      {
        "command": "korAgent.newChat",
        "title": "AI: New Chat"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "watch": "tsc -w -p ./tsconfig.json",
    "package": "vsce package"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "diff": "^5.2.0",
    "fs-extra": "^11.3.0",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.88.0",
    "@vscode/vsce": "^3.3.2",
    "typescript": "^5.8.3"
  }
}
